# ==============================
# IABS storage profile examples
# انسخ هذا الملف إلى .env ثم فعّل واحداً من النمطين بالأسفل
# ==============================

IABS_ENVIRONMENT=production
IABS_LOG_LEVEL=INFO
IABS_LOG_FORMAT=json
IABS_APP_VERSION=2.16.0
IABS_AUTH_ENABLED=true
IABS_JWT_SECRET=change-this-secret-please-use-32-chars-minimum
IABS_RATE_LIMIT_ENABLED=true
IABS_RATE_LIMIT_BACKEND=redis
IABS_REDIS_URL=redis://redis:6379/0
IABS_POSTGRES_POOL_MIN_SIZE=1
IABS_POSTGRES_POOL_MAX_SIZE=5

# ------------------------------
# النمط 1: SQLite محلي (الافتراضي)
# اترك IABS_MEMORY_DSN و DATABASE_URL فارغين
# ------------------------------
IABS_MEMORY_PATH=/app/data/memory_store.sqlite
IABS_MEMORY_DSN=
DATABASE_URL=
SUPABASE_DB_URL=
SUPABASE_DATABASE_URL=

# ------------------------------
# النمط 2: Supabase / PostgreSQL سحابي
# ضع رابط PostgreSQL هنا واترك IABS_MEMORY_PATH فارغاً
# مثال:
# IABS_MEMORY_DSN=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
# ------------------------------
# IABS_MEMORY_PATH=
# IABS_MEMORY_DSN=
